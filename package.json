{
  "name": "simplecity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PLAYWRIGHT_BROWSERS_PATH=0 next dev",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "prebuild": "npm run playwright:install",
    "build": "next build",
    "start": "PLAYWRIGHT_BROWSERS_PATH=0 next start",
    "lint": "eslint . --max-warnings=0",
    "scrape": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts",
    "scrape:headful": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts --headful",
    "scrape:download": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts --download",
    "scrape:html": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts --html",
    "scrape:foster-city": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts --jurisdiction=foster-city",
    "scrape:foster-city:full": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts --jurisdiction=foster-city --headful --html --download",
    "scrape:san-mateo-city": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts --jurisdiction=san-mateo-city",
    "scrape:san-mateo-city:full": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-primegov.ts --jurisdiction=san-mateo-city --headful --html --download",
    "scrape:santa-clara-county": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-iqm2.ts --jurisdiction=santa-clara-county",
    "scrape:santa-clara-county:headful": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-iqm2.ts --jurisdiction=santa-clara-county --headful",
    "scrape:santa-clara-county:download": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-iqm2.ts --jurisdiction=santa-clara-county --headful --download",
    "scrape:santa-clara-county:quick": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/scrape-iqm2.ts --jurisdiction=santa-clara-county --headful --download --limit=10",
    "prepare-llm": "node --import tsx/esm scripts/prepare-llm-input.ts",
    "prepare-llm:foster-city": "node --import tsx/esm scripts/prepare-llm-input.ts --jurisdiction=foster-city",
    "prepare-llm:san-mateo-city": "node --import tsx/esm scripts/prepare-llm-input.ts --jurisdiction=san-mateo-city",
    "prepare-llm:santa-clara-county": "node --import tsx/esm scripts/prepare-llm-input.ts --jurisdiction=santa-clara-county",
    "summarize": "node --import tsx/esm scripts/generate-simplecity-cards.ts",
    "summarize:foster-city": "node --import tsx/esm scripts/generate-simplecity-cards.ts --jurisdiction=foster-city",
    "summarize:san-mateo-city": "node --import tsx/esm scripts/generate-simplecity-cards.ts --jurisdiction=san-mateo-city",
    "summarize:santa-clara-county": "node --import tsx/esm scripts/generate-simplecity-cards.ts --jurisdiction=santa-clara-county",
    "pipeline": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/run-pipeline.ts",
    "pipeline:foster-city": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/run-pipeline.ts --jurisdiction=foster-city",
    "pipeline:san-mateo-city": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/run-pipeline.ts --jurisdiction=san-mateo-city",
    "pipeline:santa-clara-county": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/run-pipeline.ts --jurisdiction=santa-clara-county",
    "pipeline:all": "PLAYWRIGHT_BROWSERS_PATH=0 node --import tsx/esm scripts/run-pipeline.ts --jurisdiction=all",
    "test": "node --import tsx/esm --test tests/*.test.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.48.1",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.49.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
